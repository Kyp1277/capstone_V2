DATABASE_URL=postgresql://user:password@db-host:5432/jobfit
JOBS_SOURCE=postgres
JOBS_TABLE=jobs
HOST=0.0.0.0
PORT=5000
APP_ENV=production

# Kosongkan FRONTEND_ORIGINS jika frontend dan API berada pada domain yang sama
# melalui reverse proxy. Isi daftar origin jika frontend dan API beda domain.
FRONTEND_ORIGINS=https://jobfit.example.com,https://www.jobfit.example.com

MAX_UPLOAD_SIZE=5242880
SESSION_DAYS=30
OTP_MINUTES=10
MAX_OTP_ATTEMPTS=5

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=password_smtp
SMTP_FROM=noreply@example.com
SMTP_TLS=true
